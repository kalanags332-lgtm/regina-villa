# MongoDB connection string
# Local: mongodb://localhost:27017/reginavilla
# Railway: copy from MongoDB plugin → Variables tab → MONGO_URL or MONGODB_URL
MONGODB_URI=your_mongodb_connection_string_here

# Admin panel password — use something strong!
ADMIN_PASSWORD=change_this_to_a_strong_password

# Port (Railway sets this automatically — leave blank for Railway)
PORT=3000
